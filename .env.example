# ==========================================
# NexusCore Environment Variables
# ==========================================

# Application
ENVIRONMENT=development
API_PORT=8000

# Temporal Orchestration
TEMPORAL_HOST=localhost:7233
TEMPORAL_TASK_QUEUE=nexuscore-task-queue
TEMPORAL_MAX_CONCURRENT_ACTIVITIES=10
TEMPORAL_MAX_CONCURRENT_WORKFLOW_TASKS=20

# LLM
OPENAI_API_KEY=your_real_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_RETRIES=3

# MCP subprocess pool size — each slot spawns its own pair of subprocesses.
# Set to match TEMPORAL_MAX_CONCURRENT_ACTIVITIES for full parallel throughput.
MCP_POOL_SIZE=4

# Supervisor routing confidence gate (0.0–1.0). Temporal retries below this value.
SUPERVISOR_CONFIDENCE_THRESHOLD=0.7

# Infrastructure
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexuscore
REDIS_URL=redis://localhost:6379/0
